.placeholder-card {
  position: relative;
  z-index: 1;
  background: rgba(255, 255, 255, 0.93);
  border: 1rpx solid rgba(148, 163, 184, 0.2);
  border-radius: 28rpx;
  padding: 22rpx;
  margin-bottom: 20rpx;
}

.placeholder-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.placeholder-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.placeholder-col {
  background: #f8fafc;
  border-radius: 14rpx;
  padding: 12rpx;
}

.skeleton {
  border-radius: 10rpx;
  background: linear-gradient(110deg, #e2e8f0 8%, #f8fafc 18%, #e2e8f0 33%);
  background-size: 200% 100%;
  animation: loading 1.2s linear infinite;
}

.skeleton-title {
  width: 180rpx;
  height: 30rpx;
}

.skeleton-tip {
  width: 260rpx;
  height: 24rpx;
}

.skeleton-label {
  width: 120rpx;
  height: 24rpx;
  margin-bottom: 8rpx;
}

.skeleton-image {
  width: 100%;
  height: 280rpx;
}

@keyframes loading {
  0% {
    background-position-x: 180%;
  }
  100% {
    background-position-x: -20%;
  }
}
